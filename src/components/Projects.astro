---
// src/components/Projects.astro
---

<section id="projects" class="projects-section">
    <div class="section-container">
        <div class="section-header">
            <span class="section-tag">~/projects</span>
            <h2 class="section-title">Featured <span class="accent">Work_</span></h2>
            <p class="section-subtitle">Real-world applications demonstrating the technical-creative hybrid approach.</p>
        </div>
        <div class="projects-grid">
            <div class="project-card featured">
                <div class="project-image">
                    <img src="/smartgarden.png" alt="Smart Home IoT Hub" width="95%" height="400px">
                </div>
                <div class="project-content">
                    <div class="project-tags">
                        <span class="project-tag hardware">IoT</span>
                        <span class="project-tag">Hardware</span>
                    </div>
                    <h3 class="project-title">Smart Home IoT Hub</h3>
                    <p class="project-desc">Comprehensive home automation system built with Arduino and ESP32 microcontrollers. Features predictive energy management, remote monitoring, and automated climate control with real-time sensor analytics.</p>
                    <div class="project-tech">
                        <span>Arduino</span>
                        <span>ESP32</span>
                        <span>C++</span>
                        <span>IoT Protocols</span>
                    </div>
                </div>
            </div>
            <div class="project-card">
                <div class="project-image">
                    <div class="project-icon-large">
                        <i data-lucide="shopping-cart"></i>
                    </div>
                </div>
                <div class="project-content">
                    <div class="project-tags">
                        <span class="project-tag technical">Automation</span>
                        <span class="project-tag">POS</span>
                    </div>
                    <h3 class="project-title">Open-Source POS System</h3>
                    <p class="project-desc">Commercial-grade point-of-sale system integrated with n8n AI agents for inventory automation and sales analytics.</p>
                    <div class="project-tech">
                        <span>Node.js</span>
                        <span>n8n</span>
                        <span>AI Agents</span>
                    </div>
                </div>
            </div>
            <div class="project-card">
                <div class="project-image">
                    <img src="/bbc.png" alt="Brand Identity Portfolio" width="100%" height="185px">
                </div>
                <div class="project-content">
                    <div class="project-tags">
                        <span class="project-tag creative">Branding</span>
                        <span class="project-tag">Design</span>
                    </div>
                    <h3 class="project-title">Brand Identity Portfolio</h3>
                    <p class="project-desc">250+ hours of professional brand asset creation including logos, marketing materials, and complete visual identity systems.</p>
                    <div class="project-tech">
                        <span>Illustrator</span>
                        <span>Photoshop</span>
                        <span>Vector Graphics</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>