---
// src/components/Skills.astro
import "../styles/global.css";
---

<section id="skills" class="skills-section">
    <div class="section-container">
        <div class="section-header">
            <span class="section-tag">~/skills</span>
            <h2 class="section-title">Technical <span class="accent">Capabilities_</span></h2>
            <p class="section-subtitle">A hybrid skillset combining development, hardware diagnostics, and design systems.</p>
        </div>
        <div class="skills-grid">
            <div class="skills-category">
                <div class="skills-header">
                    <i data-lucide="code-2"></i>
                    <h3>Development</h3>
                </div>
                <div class="skills-list">
                    <div class="skill-item">
                        <span class="skill-name">Web Development</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 95%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Mobile Applications</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 85%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">AI Integration (OpenAI, n8n)</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 90%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">JavaScript / Node.js</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 88%"></div></div>
                    </div>
                </div>
            </div>
            <div class="skills-category">
                <div class="skills-header">
                    <i data-lucide="cpu"></i>
                    <h3>Hardware & Software</h3>
                </div>
                <div class="skills-list">
                    <div class="skill-item">
                        <span class="skill-name">Network Diagnostics</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 92%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">System Administration</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 88%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">IoT Solutions (Arduino/ESP32)</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 85%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Hardware Troubleshooting</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 90%"></div></div>
                    </div>
                </div>
            </div>
            <div class="skills-category">
                <div class="skills-header">
                    <i data-lucide="pen-tool"></i>
                    <h3>Design Tools</h3>
                </div>
                <div class="skills-list">
                    <div class="skill-item">
                        <span class="skill-name">Adobe Illustrator</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 95%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Adobe Photoshop</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 90%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Brand Identity Systems</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 92%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Vector Asset Production</span>
                        <div class="skill-bar"><div class="skill-fill" style="width: 94%"></div></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="tech-stack">
            <span class="stack-label">Primary Stack:</span>
            <div class="stack-tags">
                <span class="stack-tag">HTML5</span>
                <span class="stack-tag">CSS3</span>
                <span class="stack-tag">JavaScript</span>
                <span class="stack-tag">Node.js</span>
                <span class="stack-tag">Vercel</span>
                <span class="stack-tag">Arduino</span>
                <span class="stack-tag">ESP32</span>
            </div>
        </div>
    </div>
</section>