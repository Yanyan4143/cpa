---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <!-- About Page (Home/Landing) - Professional Left/Right Layout -->
    <div id="page-about" class="page active">
        <div class="hero">
            <div class="hero-container">
                <!-- Left Side: Content -->
                <div class="hero-content">
                    <!-- Badge -->
                    <div class="hero-badge">
                        <span class="status-dot"></span>
                        <span class="status-text">System Online — 500h Professional Experience</span>
                    </div>

                    <!-- Title -->
                    <h1 class="hero-title">
                        <span class="title-line">Technical-Creative</span>
                        <span class="title-line gradient-text">Hybrid_</span>
                    </h1>

                    <!-- Subtitle -->
                    <p class="hero-subtitle">
                        <span class="typing-text" id="typingText">Optimizing System Integrity and Visual Identity</span>
                        <span class="terminal-cursor-blink">|</span>
                    </p>

                    <!-- Description -->
                    <p class="hero-description">
                        BSIT Graduate bridging the gap between hardware-software solutions and high-standard digital branding. 
                        Specialized in AI-Integrated Web Development, IoT implementations, and enterprise-grade visual identity systems.
                    </p>

                    <!-- Stats -->
                    <div class="hero-stats">
    <div class="stat-item">
        <span class="stat-value">500h</span>
        <span class="stat-label">Internship Hours</span>
    </div>
    <div class="stat-item">
        <span class="stat-value">1yr</span>
        <span class="stat-label">AI-Integrated Freelance</span>
    </div>
    <div class="stat-item">
        <span class="stat-value">150+</span>
        <span class="stat-label">Brand Assets Delivered</span>
    </div>
</div>

                    <!-- Language Bar -->
                    <div class="language-bar">
                        <span class="lang-label">Linguistic Proficiency:</span>
                        <span class="lang-tag">English (C1)</span>
                        <span class="lang-tag">Tagalog (C2)</span>
                        <span class="lang-tag">Cebuano (C2)</span>
                    </div>

                    <!-- CTA Buttons -->
                    <div class="hero-cta">
                        <a href="#experience" class="btn btn-primary" id="cta-experience">
                            <i data-lucide="terminal"></i>
                            View Experience
                        </a>
                        <a href="#contact" class="btn btn-secondary" id="cta-contact">
                            <i data-lucide="mail"></i>
                            Get in Touch
                        </a>
                    </div>
                </div>

                <!-- Right Side: Profile Picture -->
                <div class="hero-profile">
                    <div class="profile-frame">
                        <img src="/yanyan.png" alt="Christian Paul Atillo" class="profile-picture">
                        <div class="profile-glow"></div>
                    </div>
                    <div class="profile-name">
                        <h3>Christian Paul Atillo</h3>
                        <p>BSIT Graduate | Tech-Creative Hybrid</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Experience Page -->
    <div id="page-experience" class="page">
        <div class="experience-section">
            <div class="section-container">
                <div class="section-header">
                    <span class="section-tag">~/experience</span>
                    <h2 class="section-title">Professional <span class="accent">Experience_</span></h2>
                    <p class="section-subtitle">A proven track record in hardware-software solutions and visual identity systems.</p>
                </div>
                <div class="exp-grid">
                    <div class="exp-card">
                        <div class="exp-header">
                            <div class="exp-icon tech-icon">
                                <i data-lucide="server"></i>
                            </div>
                            <div class="exp-meta">
                                <span class="exp-hours">250h</span>
                                <span class="exp-badge">Internship</span>
                            </div>
                        </div>
                        <h3 class="exp-title">IT Support Specialist</h3>
                        <p class="exp-company">Basak San Nicolas Barangay Hall</p>
                        <ul class="exp-details">
                            <li><i data-lucide="check-circle"></i>Optimized workstation performance across 50+ government terminals</li>
                            <li><i data-lucide="check-circle"></i>Resolved complex network connectivity issues</li>
                            <li><i data-lucide="check-circle"></i>Implemented hardware diagnostics protocols reducing downtime by 40%</li>
                            <li><i data-lucide="check-circle"></i>Managed system integrity for critical public service operations</li>
                        </ul>
                    </div>
                    <div class="exp-card">
                        <div class="exp-header">
                            <div class="exp-icon design-icon">
                                <i data-lucide="palette"></i>
                            </div>
                            <div class="exp-meta">
                                <span class="exp-hours">250h</span>
                                <span class="exp-badge">Internship</span>
                            </div>
                        </div>
                        <h3 class="exp-title">Graphic Designer</h3>
                        <p class="exp-company">Creative Agency / Freelance</p>
                        <ul class="exp-details">
                            <li><i data-lucide="check-circle"></i>Delivered 150+ vector-based brand assets using Adobe Illustrator</li>
                            <li><i data-lucide="check-circle"></i>Executed advanced photo manipulation for corporate campaigns</li>
                            <li><i data-lucide="check-circle"></i>Developed comprehensive visual identity systems for SMBs</li>
                            <li><i data-lucide="check-circle"></i>Created marketing collateral with measurable engagement lift</li>
                        </ul>
                    </div>
                </div>
                <div class="freelance-highlight">
                    <div class="freelance-badge">
                        <i data-lucide="trending-up"></i>
                        <span>Freelance Portfolio</span>
                    </div>
                    <h3>AI-Integrated Development Studio</h3>
                    <p>1+ year of independent web and mobile application development, leveraging AI-powered tools and low-code platforms for rapid deployment.</p>
                    <div class="freelance-tags">
                        <span class="tag">Web Development</span>
                        <span class="tag">Mobile Apps</span>
                        <span class="tag">AI Integration</span>
                        <span class="tag">Low-Code Platforms</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Skills Page -->
    <div id="page-skills" class="page">
        <div class="skills-section">
            <div class="section-container">
                <div class="section-header">
                    <span class="section-tag">~/skills</span>
                    <h2 class="section-title">Technical <span class="accent">Capabilities_</span></h2>
                    <p class="section-subtitle">A hybrid skillset combining development, hardware diagnostics, and design systems.</p>
                </div>
                <div class="skills-grid">
                    <div class="skills-category">
                        <div class="skills-header">
                            <i data-lucide="code-2"></i>
                            <h3>Development</h3>
                        </div>
                        <div class="skills-list">
                            <div class="skill-item">
                                <span class="skill-name">Web Development</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 95%"></div></div>
                            </div>
                            <div class="skill-item">
                                <span class="skill-name">Mobile Applications</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 85%"></div></div>
                            </div>
                            <div class="skill-item">
                                <span class="skill-name">AI Integration (OpenAI, n8n)</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 90%"></div></div>
                            </div>
                            <div class="skill-item">
                                <span class="skill-name">JavaScript / Node.js</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 88%"></div></div>
                            </div>
                        </div>
                    </div>
                    <div class="skills-category">
                        <div class="skills-header">
                            <i data-lucide="cpu"></i>
                            <h3>Hardware & Software</h3>
                        </div>
                        <div class="skills-list">
                            <div class="skill-item">
                                <span class="skill-name">Network Diagnostics</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 92%"></div></div>
                            </div>
                            <div class="skill-item">
                                <span class="skill-name">System Administration</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 88%"></div></div>
                            </div>
                            <div class="skill-item">
                                <span class="skill-name">IoT Solutions (Arduino/ESP32)</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 85%"></div></div>
                            </div>
                            <div class="skill-item">
                                <span class="skill-name">Hardware Troubleshooting</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 90%"></div></div>
                            </div>
                        </div>
                    </div>
                    <div class="skills-category">
                        <div class="skills-header">
                            <i data-lucide="pen-tool"></i>
                            <h3>Design Tools</h3>
                        </div>
                        <div class="skills-list">
                            <div class="skill-item">
                                <span class="skill-name">Adobe Illustrator</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 95%"></div></div>
                            </div>
                            <div class="skill-item">
                                <span class="skill-name">Adobe Photoshop</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 90%"></div></div>
                            </div>
                            <div class="skill-item">
                                <span class="skill-name">Brand Identity Systems</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 92%"></div></div>
                            </div>
                            <div class="skill-item">
                                <span class="skill-name">Vector Asset Production</span>
                                <div class="skill-bar"><div class="skill-fill" style="width: 94%"></div></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="tech-stack">
                    <span class="stack-label">Primary Stack:</span>
                    <div class="stack-tags">
                        <span class="stack-tag">HTML5</span>
                        <span class="stack-tag">CSS3</span>
                        <span class="stack-tag">JavaScript</span>
                        <span class="stack-tag">Node.js</span>
                        <span class="stack-tag">Vercel</span>
                        <span class="stack-tag">Arduino</span>
                        <span class="stack-tag">ESP32</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Page -->
    <div id="page-projects" class="page">
        <div class="projects-section">
            <div class="section-container">
                <div class="section-header">
                    <span class="section-tag">~/projects</span>
                    <h2 class="section-title">Featured <span class="accent">Work_</span></h2>
                    <p class="section-subtitle">Real-world applications demonstrating the technical-creative hybrid approach.</p>
                </div>
                <div class="projects-grid">
                    <div class="project-card featured">
                        <div class="project-image">
                            <img src="/smartgarden.png" alt="Smart Home IoT Hub">
                        </div>
                        <div class="project-content">
                            <div class="project-tags">
                                <span class="project-tag hardware">IoT</span>
                                <span class="project-tag">Hardware</span>
                            </div>
                            <h3 class="project-title">Smart Home IoT Hub</h3>
                            <p class="project-desc">Comprehensive home automation system built with Arduino and ESP32 microcontrollers.</p>
                            <div class="project-tech">
                                <span>Arduino</span>
                                <span>ESP32</span>
                                <span>C++</span>
                                <span>IoT Protocols</span>
                            </div>
                        </div>
                    </div>
                    <div class="project-card">
                        <div class="project-image">
                            <div class="project-icon-large">
                                <i data-lucide="shopping-cart"></i>
                            </div>
                        </div>
                        <div class="project-content">
                            <div class="project-tags">
                                <span class="project-tag technical">Automation</span>
                                <span class="project-tag">POS</span>
                            </div>
                            <h3 class="project-title">Open-Source POS System</h3>
                            <p class="project-desc">Commercial-grade point-of-sale system integrated with n8n AI agents.</p>
                            <div class="project-tech">
                                <span>Node.js</span>
                                <span>n8n</span>
                                <span>AI Agents</span>
                            </div>
                        </div>
                    </div>
                    <div class="project-card">
                        <div class="project-image">
                            <img src="/bbc.png" alt="Brand Identity Portfolio">
                        </div>
                        <div class="project-content">
                            <div class="project-tags">
                                <span class="project-tag creative">Branding</span>
                                <span class="project-tag">Design</span>
                            </div>
                            <h3 class="project-title">Brand Identity Portfolio</h3>
                            <p class="project-desc">250+ hours of professional brand asset creation including logos and visual identity systems.</p>
                            <div class="project-tech">
                                <span>Illustrator</span>
                                <span>Photoshop</span>
                                <span>Vector Graphics</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact Page -->
    <div id="page-contact" class="page">
        <div class="contact-section">
            <div class="section-container">
                <div class="section-header">
                    <span class="section-tag">~/contact</span>
                    <h2 class="section-title">Let's <span class="accent">Connect_</span></h2>
                    <p class="section-subtitle">Ready to bridge hardware-software solutions with your next project?</p>
                </div>
                <div class="contact-grid">
                    <div class="contact-info">
                        <div class="contact-item">
                            <div class="contact-icon">
                                <i data-lucide="mail"></i>
                            </div>
                            <div class="contact-detail">
                                <span class="contact-label">Email</span>
                                <a href="mailto:cupcakeninja241@gmail.com" class="contact-value">cupcakeninja241@gmail.com</a>
                            </div>
                        </div>
                        <div class="contact-item">
                            <div class="contact-icon">
                                <i data-lucide="map-pin"></i>
                            </div>
                            <div class="contact-detail">
                                <span class="contact-label">Location</span>
                                <span class="contact-value">Cebu, Philippines</span>
                            </div>
                        </div>
                        <div class="contact-item">
                            <div class="contact-icon">
                                <i data-lucide="languages"></i>
                            </div>
                            <div class="contact-detail">
                                <span class="contact-label">Languages</span>
                                <span class="contact-value">English (C1) · Tagalog (C2) · Cebuano (C2)</span>
                            </div>
                        </div>
                    </div>
                    <div class="contact-cta-box">
                        <h3>Start a Conversation</h3>
                        <p>Whether you need IT support, a brand refresh, or an AI-integrated web solution, I'm ready to deliver.</p>
                        
                        <form id="contact-form" class="contact-form">
                            <input type="text" name="_honey" style="display:none">
                            <input type="hidden" name="_captcha" value="false">
                            
                            <div class="form-group">
                                <input type="text" id="form-name" name="name" placeholder="Your Name" required>
                            </div>
                            <div class="form-group">
                                <input type="email" id="form-email" name="email" placeholder="Your Email" required>
                            </div>
                            <div class="form-group">
                                <textarea id="form-message" name="message" placeholder="Your Message" rows="4" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-large" id="submit-btn">
                                <i data-lucide="send"></i>
                                Send Message
                            </button>
                        </form>
                        
                        <div class="form-note">
                            <p style="color: var(--text-secondary); font-size: 0.75rem; text-align: center; margin-top: 1rem;">
                                I'll respond within 24 hours
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<!-- Professional Success Modal -->
<div id="success-modal" class="success-modal">
    <div class="success-modal-content">
        <div class="success-icon">✓</div>
        <h3 class="success-title">Message Sent Successfully!</h3>
        <p class="success-message">Thank you for reaching out. I've received your message and will get back to you within 24 hours.</p>
        <button class="success-btn" onclick="closeSuccessModal()">OK</button>
    </div>
</div>

<script>
    // Smooth page navigation
    document.addEventListener('DOMContentLoaded', () => {
        const navButtons = document.querySelectorAll('[data-page]');
        const pages = document.querySelectorAll('.page');
        
        function showPage(pageId) {
            pages.forEach(page => {
                page.classList.remove('active');
            });
            const activePage = document.getElementById(`page-${pageId}`);
            if (activePage) {
                activePage.classList.add('active');
            }
            navButtons.forEach(btn => {
                if (btn.getAttribute('data-page') === pageId) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        
        navButtons.forEach(button => {
            button.addEventListener('click', (e) => {
                e.preventDefault();
                const pageId = button.getAttribute('data-page');
                showPage(pageId);
                history.pushState({ page: pageId }, '', `#${pageId}`);
            });
        });
        
        const ctaExperience = document.getElementById('cta-experience');
        const ctaContact = document.getElementById('cta-contact');
        
        if (ctaExperience) {
            ctaExperience.addEventListener('click', (e) => {
                e.preventDefault();
                showPage('experience');
                history.pushState({ page: 'experience' }, '', '#experience');
            });
        }
        
        if (ctaContact) {
            ctaContact.addEventListener('click', (e) => {
                e.preventDefault();
                showPage('contact');
                history.pushState({ page: 'contact' }, '', '#contact');
            });
        }
        
        const hash = window.location.hash.slice(1);
        if (hash && ['about', 'experience', 'skills', 'projects', 'contact'].includes(hash)) {
            showPage(hash);
        }
    });
    
    // Form submission
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    
    function showSuccessModal() {
        const modal = document.getElementById('success-modal');
        if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        if (form) form.reset();
        if (typeof lucide !== 'undefined') lucide.createIcons();
    }
    
    window.closeSuccessModal = function() {
        const modal = document.getElementById('success-modal');
        if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = '';
        }
    };
    
    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const name = document.getElementById('form-name')?.value;
            const email = document.getElementById('form-email')?.value;
            const message = document.getElementById('form-message')?.value;
            
            if (!name || !email || !message) return;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i data-lucide="loader-2"></i> Sending...';
            if (typeof lucide !== 'undefined') lucide.createIcons();
            
            try {
                const formData = new FormData();
                formData.append('name', name);
                formData.append('email', email);
                formData.append('message', message);
                formData.append('_captcha', 'false');
                
                const response = await fetch('https://formsubmit.co/ajax/cupcakeninja241@gmail.com', {
                    method: 'POST',
                    body: formData
                });
                
                if (response.ok) {
                    showSuccessModal();
                } else {
                    throw new Error('Failed');
                }
            } catch (error) {
                alert('Failed to send. Please email me directly at cupcakeninja241@gmail.com');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i data-lucide="send"></i> Send Message';
                if (typeof lucide !== 'undefined') lucide.createIcons();
            }
        });
    }
    
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeSuccessModal();
    });
    
    const modal = document.getElementById('success-modal');
    if (modal) {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeSuccessModal();
        });
    }
</script>
